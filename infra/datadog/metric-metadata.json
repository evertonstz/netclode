{
  "netclode.sessions.active": {
    "type": "gauge",
    "unit": "session",
    "description": "Number of active sessions"
  },
  "netclode.sessions.created": {
    "type": "count",
    "unit": "session",
    "description": "Sessions created"
  },
  "netclode.sessions.paused": {
    "type": "count",
    "unit": "session",
    "description": "Sessions paused"
  },
  "netclode.sandbox.create.duration_ms": {
    "type": "gauge",
    "unit": "millisecond",
    "description": "Sandbox creation duration"
  },
  "netclode.connect.clients": {
    "type": "gauge",
    "unit": "connection",
    "description": "Connected bidi-stream clients"
  },
  "netclode.connect.agents.registered": {
    "type": "count",
    "unit": "connection",
    "description": "Agent registrations"
  },
  "netclode.redis.stream.depth": {
    "type": "gauge",
    "unit": "message",
    "description": "Redis stream pending message count"
  },
  "netclode.proxy.requests": {
    "type": "count",
    "unit": "request",
    "description": "Proxy requests"
  },
  "netclode.proxy.auth.duration_ms": {
    "type": "gauge",
    "unit": "millisecond",
    "description": "Auth validation duration"
  },
  "netclode.proxy.auth.errors": {
    "type": "count",
    "unit": "error",
    "description": "Auth validation errors"
  },
  "netclode.proxy.secrets.injected": {
    "type": "count",
    "unit": "operation",
    "description": "Secrets injected into requests"
  },
  "netclode.ghbot.webhook.received": {
    "type": "count",
    "unit": "event",
    "description": "GitHub webhooks received"
  },
  "netclode.ghbot.mention.triggered": {
    "type": "count",
    "unit": "event",
    "description": "@netclode mention triggers"
  },
  "netclode.ghbot.depbot.triggered": {
    "type": "count",
    "unit": "event",
    "description": "Dependency bot review triggers"
  },
  "netclode.ghbot.session.duration_ms": {
    "type": "gauge",
    "unit": "millisecond",
    "description": "Bot session total duration"
  }
}
